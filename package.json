  "repository": {
    "type": "git",
    "url": "https://github.com/samuelrkestenbaum-dot/gravito-eval.git"
  },
  "homepage": "https://gravito.ai",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
