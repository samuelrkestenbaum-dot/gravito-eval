{
  "name": "gravito-eval",
  "version": "0.3.3",
  "description": "Scan any website — see what's wrong, what's missing, and what a human reviewer would miss.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gravito-eval": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "website-scanner",
    "ai-evaluation",
    "governance",
    "alignment",
    "content-audit",
    "compliance",
    "llm-evaluation",
    "prompt-testing",
    "ai-qa",
    "website-analysis"
  ],
  "author": "Gravito <hello@gravitoai.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/samuelrkestenbaum-dot/gravito-eval.git"
  },
  "homepage": "https://gravito.ai",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
