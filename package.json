{
  "name": "gravito-eval",
  "version": "0.1.0",
  "description": "Measure how closely AI decisions match human judgment — and where they add new signal.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gravito-eval": "dist/cli/index.js"
  },
  "files": [
